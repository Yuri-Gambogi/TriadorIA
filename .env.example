# Triador AI — environment variables template
# Copie para .env.local (que é gitignored) e preencha com valores reais do Supabase
#
# Como obter:
#  - Supabase Dashboard → Settings → API → Project URL + anon public + service_role
#  - Supabase Dashboard → Settings → Database → Connection string (URI), substituindo [YOUR-PASSWORD]
#
# IMPORTANTE: Vercel NÃO lê .env.local. Para deploy, adicionar essas vars no
# Vercel Dashboard → Settings → Environment Variables (Production + Preview + Development).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Database (Drizzle direct connection via postgres.js) ---
# Use o "Connection string" do Supabase (URI mode), substituindo [YOUR-PASSWORD]
DATABASE_URL=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
